{
  "name": "vscode-tabular",
  "displayName": "Tabular Viewing Mode",
  "description": "A simple global viewing mode that adds test decorations to any text editor.",
  "version": "0.0.1",
  "publisher": "local",
  "repository": {
    "type": "git",
    "url": "https://github.com/SanderVocke/vscode-tabular.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:tabularViewingMode.toggle",
    "onCommand:tabularViewingMode.applyAlignment",
    "onCommand:tabularViewingMode.compactCells"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "tabularViewingMode.toggle",
        "title": "Tabular: Edit As Aligned"
      },
      {
        "command": "tabularViewingMode.applyAlignment",
        "title": "Tabular: Align Content"
      },
      {
        "command": "tabularViewingMode.compactCells",
        "title": "Tabular: Compact Content"
      }
    ]
  },
  "scripts": {
    "lint": "node --check extension.js && node --check lib/tabular.js && node --check test/tabular.test.js",
    "test": "node test/tabular.test.js",
    "build:vsix": "npm run lint && npm test && vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.9.2"
  }
}
